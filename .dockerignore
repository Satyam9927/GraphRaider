# Build context exclusions — keep the image small and secrets out.
.git
.gitignore
README.md
*.md

# Python
venv/
.venv/
__pycache__/
*.py[cod]

# Node
frontend/node_modules/
npm-debug.log*

# Local state (never bake tokens / logs into the image; the example IS kept)
storage/config.json
storage/request_log.json
.graphraider.pids

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
